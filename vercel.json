    "JWT_SECRET": "4770c07d82c75bee14deb391083a7cb62ab28b4fe811667be9aee6d73b96d323",
    "ALLOWED_ORIGINS": "https://batticloa-library-management-system.vercel.app",
    "DLP_API_URL": "https://batticaloa.dlp.gov.lk/api/v1",
