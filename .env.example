# Batticaloa Public Library — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values for local development.
# For Vercel production, set all variables in:
#   Vercel Dashboard → Project → Settings → Environment Variables
# NEVER commit .env (it is gitignored).

# App
NODE_ENV=development
PORT=3000

# CORS — comma-separated allowed origins
# Production example: https://battilibrary.lk,https://www.battilibrary.lk
ALLOWED_ORIGINS=http://localhost:3000

# Database (Turso / libSQL)
# Sign up at https://turso.tech and create a free database.
# For local dev you can leave these blank — a local file: SQLite will be used.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# JWT signing secret — generate with: openssl rand -hex 32
# Must be at least 32 characters. Required in production.
JWT_SECRET=

# Koha OPAC proxy (Eastern University library catalog)
KOHA_OPAC_URL=https://www.opac.lib.esn.ac.lk

# DLP Koha API (Batticaloa Public Library catalog sync)
DLP_API_URL=
DLP_CLIENT_ID=
DLP_CLIENT_SECRET=
